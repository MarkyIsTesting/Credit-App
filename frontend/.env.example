# ===== Frontend configuration =====
# Copy to `.env` and adjust. REACT_APP_* vars are baked at BUILD time.

# Base URL of the backend API.
#  - Local dev (separate ports):     http://localhost:8001
#  - Same-origin prod behind nginx:  leave EMPTY so the app calls a relative "/api"
REACT_APP_BACKEND_URL=http://localhost:8001
