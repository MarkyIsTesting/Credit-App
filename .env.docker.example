# ===== docker-compose configuration =====
# Copy to `.env` (same directory as docker-compose.yml) and edit before deploying.

# Public URL where the app is reachable (used for CORS + email links).
# Local:      http://localhost:8080
# Production: https://votre-domaine.fr
PUBLIC_URL=http://localhost:8080

# Host port to expose the app on.
HTTP_PORT=8080

# Database name.
DB_NAME=eurokredit

# REQUIRED — generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret

# Cookie policy. HTTP local: false/lax. HTTPS production: true/lax.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Seed admin account (created on first startup).
ADMIN_EMAIL=admin@eurokredit.fr
ADMIN_PASSWORD=Admin2026!

# Email (optional). Leave SMTP_HOST empty to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@eurokredit.fr
SMTP_STARTTLS=true
SMTP_SSL=false
EMAIL_FROM_NAME=EuroKredit
