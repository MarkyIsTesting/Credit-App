# ===== Backend configuration =====
# Copy this file to `.env` and adjust values. `.env` is gitignored.

# --- Database (required) ---
# Local MongoDB :
MONGO_URL=mongodb://localhost:27017
# ...ou MongoDB Atlas (cloud gratuit, aucune install locale) :
# MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=eurokredit

# --- Auth (required) ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret

# --- Cookie policy ---
# Local HTTP dev:            COOKIE_SECURE=false  COOKIE_SAMESITE=lax
# Cross-site HTTPS prod:     COOKIE_SECURE=true   COOKIE_SAMESITE=none
# Same-origin HTTPS (nginx): COOKIE_SECURE=true   COOKIE_SAMESITE=lax
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- CORS ---
# Comma-separated list of allowed frontend origins (NO wildcard with cookies).
CORS_ORIGINS=http://localhost:3000

# --- Frontend URL used inside notification emails (links back to the app) ---
FRONTEND_URL=http://localhost:3000

# --- Server ---
HOST=0.0.0.0
PORT=8001
RELOAD=false

# --- Seed admin account (created/updated on startup) ---
ADMIN_EMAIL=admin@eurokredit.fr
ADMIN_PASSWORD=Admin2026!

# --- Email (SMTP, optional — leave SMTP_HOST empty to disable email sending) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@eurokredit.fr
SMTP_STARTTLS=true
SMTP_SSL=false
EMAIL_FROM_NAME=EuroKredit
